# Shared
NODE_ENV=development

# API
PORT=4000
DATABASE_URL=postgresql://ironlog:ironlog@localhost:5433/ironlog
REDIS_URL=redis://localhost:6379
OPENAI_API_KEY=your_openai_api_key_here
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN_DAYS=14
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=20
WEEKLY_REPORT_CRON=0 6 * * 1
WEEKLY_REPORT_RECIPIENT=gm@ironlog.local
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@yourdomain.com
SMTP_PASSWORD=replace_me
SMTP_FROM=IRONLOG <mailer@yourdomain.com>
SYNTHETIC_LOAD_CRON=
SYNTHETIC_LOAD_DEFAULT_SITE_CODE=SITE-A
SYNTHETIC_LOAD_DEFAULT_DAYS=7
SYNTHETIC_LOAD_DEFAULT_MACHINES=EQ-1001,EQ-1002,EQ-1007,EQ-1010
SYNTHETIC_LOAD_DEFAULT_EVENTS_PER_DAY_PER_MACHINE=3
SYNTHETIC_LOAD_DEFAULT_INCLUDE_CRITICAL_SPIKE=true
ADMIN_EMAIL=admin@ironlog.local
ADMIN_NAME=System Admin
ADMIN_PASSWORD=ChangeMe123!

# Web
VITE_API_BASE_URL=http://localhost:4000/api
