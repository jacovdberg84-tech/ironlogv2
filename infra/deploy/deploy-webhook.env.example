DEPLOY_WEBHOOK_PORT=9000
DEPLOY_WEBHOOK_HOST=127.0.0.1
DEPLOY_WEBHOOK_TOKEN=replace-with-strong-random-token
DEPLOY_WEBHOOK_LOG_FILE=/var/log/ironlog-deploy-webhook.log

# DEPLOY_COMMAND receives DEPLOY_REF and DEPLOY_ENVIRONMENT env vars.
DEPLOY_COMMAND=cd /opt/ironlogv2 && git pull --ff-only && npm ci && npm --workspace apps/api run build && npm --workspace apps/web run build && pm2 restart ironlog-api && systemctl reload nginx
