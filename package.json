{
  "name": "ironlog-v2",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "backup:db": "powershell -ExecutionPolicy Bypass -File ./scripts/db-backup.ps1",
    "restore:db": "powershell -ExecutionPolicy Bypass -File ./scripts/db-restore.ps1",
    "smoke:test": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1"
  }
}
